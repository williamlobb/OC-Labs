# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CoWork — required
COWORK_API_URL=https://cowork.theoc.ai/api
COWORK_API_KEY=your-cowork-api-key

# GitHub — optional, raises API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your-personal-access-token

# Slack webhooks — optional
SLACK_WEBHOOK_PROJECTS=https://hooks.slack.com/services/...
# Optional: set this to a private owner-only destination for hand-raise alerts.
SLACK_WEBHOOK_HAND_RAISES=https://hooks.slack.com/services/...
SLACK_WEBHOOK_WINS=https://hooks.slack.com/services/...

# Resend — required for email digest
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=OC Labs <noreply@labs.theoc.ai>

# Cron — required to secure the digest endpoint
CRON_SECRET=your-cron-secret

# Jira — required for manual Plan task sync
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@theoc.ai
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=OC
JIRA_ISSUE_TYPE=Task

# App URL — used in emails and Slack notifications
NEXT_PUBLIC_APP_URL=https://oclabs.space

# Anthropic — required for AI features (Plan tab, Chat tab)
ANTHROPIC_API_KEY=sk-ant-your-key

# Go agent — required for project chat. Must use https:// — Fly.io redirects http→https
# with a 301 which causes fetch() to downgrade POST→GET, producing 405 from the agent.
AGENT_URL=https://oclabs-agent.fly.dev

# Go agent models — optional intelligent routing
# General chat model
AGENT_MODEL_GENERAL=claude-sonnet-4-6
# Repository/codebase reading model
AGENT_MODEL_REPO_READ=claude-sonnet-4-5
