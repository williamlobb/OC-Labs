# Supabase — required
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CoWork — required
COWORK_API_URL=https://cowork.theoc.ai/api
COWORK_API_KEY=your-cowork-api-key

# GitHub — optional, raises API rate limit from 60 to 5000 req/hr
GITHUB_TOKEN=ghp_your-personal-access-token

# Slack webhooks — optional
SLACK_WEBHOOK_PROJECTS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_WINS=https://hooks.slack.com/services/...

# Resend — optional, used for email digest (not yet implemented)
RESEND_API_KEY=re_your-resend-api-key
